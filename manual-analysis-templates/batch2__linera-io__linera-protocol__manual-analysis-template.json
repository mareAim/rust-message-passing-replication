{
  "purpose": "Manual coding template for analysing how message-passing channels are used in a Rust repository.",
  "important_rule": "Answers are coded per uniformly randomly sampled, feasible channel-containing production file from the pinned Git commit. They do not claim that every channel occurrence in the repository was inspected.",
  "sampling_protocol": {
    "selection_method": "filtered_uniform_random_file_sample",
    "source": "git_commit",
    "commit": "60b5f7f69178132b29eaa18ae28a653eda5c78e9",
    "random_seed": 42,
    "requested_sample_size": 5,
    "actual_sample_size": 5,
    "candidate_count": 35,
    "max_file_lines": 6000,
    "candidate_query": "rg -n \"channel\\(|unbounded_channel|sync_channel|broadcast::channel|oneshot::channel|watch::channel|flume::|crossbeam_channel|async_channel\"",
    "candidate_query_keywords": [
      "channel(",
      "unbounded_channel",
      "sync_channel",
      "broadcast::channel",
      "oneshot::channel",
      "watch::channel",
      "flume::",
      "crossbeam_channel",
      "async_channel"
    ],
    "excluded_path_pattern": "(^|/)(test|tests|example|examples|bench|benches|mock|mocks|fixture|fixtures)(/|_)|_test\\.rs$|_tests\\.rs$|test\\.rs$|tests\\.rs$",
    "excluded_dirs": [
      ".direnv",
      ".git",
      ".idea",
      ".vscode",
      "node_modules",
      "target"
    ],
    "generated_markers": [
      "@generated",
      "automatically generated",
      "auto-generated",
      "autogenerated",
      "generated by",
      "code generated"
    ],
    "included": "Rust source files at the pinned commit that match the channel keyword query and pass the filters.",
    "excluded": "Tests, examples, benchmarks, mocks, fixtures, generated files where identifiable, skipped directories, and files above 6000 lines.",
    "not_relevant_policy": "A selected file is kept in the sample even if manual inspection finds no relevant message-passing channel use. It is marked with sample_status=not_relevant and counted separately in results.",
    "aggregation_rule": "Each sampled file is coded independently. Results are reported as counts/distributions across sampled files; no repository-level final structure, role, or importance labels are assigned."
  },
  "repo_analysis": {
    "repo": "linera-io/linera-protocol",
    "github_commit": "60b5f7f69178132b29eaa18ae28a653eda5c78e9",
    "date": "",
    "question_template": [
      {
        "id": "q01_clear_receiver_owner",
        "question": "Is clearly identifiable receiver ownership present in this sampled file?"
      },
      {
        "id": "q02_sender_cloning",
        "question": "Are sender handles cloned or shared in this sampled file?"
      },
      {
        "id": "q03_receiver_loop",
        "question": "Are receivers consumed in long-running loops in this sampled file?"
      },
      {
        "id": "q04_mailbox_pattern",
        "question": "Does this sampled file contain a component-mailbox pattern?"
      },
      {
        "id": "q05_fan_in",
        "question": "Does this sampled file contain fan-in message passing?"
      },
      {
        "id": "q06_fan_out",
        "question": "Does this sampled file contain fan-out or pub-sub message passing?"
      },
      {
        "id": "q07_worker_queue",
        "question": "Does this sampled file contain a worker-queue pattern?"
      },
      {
        "id": "q08_shutdown_signal",
        "question": "Does this sampled file use channels for shutdown, readiness, or cancellation signaling?"
      },
      {
        "id": "q09_data_transport",
        "question": "Does message passing transport runtime data in this sampled file?"
      },
      {
        "id": "q10_command_messages",
        "question": "Does message passing carry command-style messages in this sampled file?"
      },
      {
        "id": "q11_notification_messages",
        "question": "Does message passing carry lightweight notifications or signals in this sampled file?"
      },
      {
        "id": "q12_background_dispatch",
        "question": "Does message passing dispatch work to a background thread or async task in this sampled file?"
      },
      {
        "id": "q13_cross_thread_usage",
        "question": "Does message passing cross OS-thread boundaries in this sampled file?"
      },
      {
        "id": "q14_cross_async_task_usage",
        "question": "Does message passing cross async-task boundaries in this sampled file?"
      }
    ],
